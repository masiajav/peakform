{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "Replaid Coach Overlay",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.269.0",
    "author": "Replaid Lab",
    "icon": "icon.png"
  },
  "data": {
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [10844]
    },
    "start_window": "background",
    "windows": {
      "background": {
        "file": "index.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "size": {
          "width": 360,
          "height": 220
        }
      },
      "ingame": {
        "file": "index.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "in_game_only": true,
        "size": {
          "width": 420,
          "height": 260
        },
        "position": {
          "top": 72,
          "right": 36
        }
      },
      "debug": {
        "file": "debug.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "size": {
          "width": 960,
          "height": 680
        }
      }
    },
    "hotkeys": {
      "toggle_overlay": {
        "title": "Mostrar u ocultar Replaid Coach",
        "action-type": "custom",
        "default": "Ctrl+Shift+R"
      },
      "open_debug": {
        "title": "Abrir debug de eventos",
        "action-type": "custom",
        "default": "Ctrl+Shift+D"
      }
    }
  },
  "permissions": ["GameInfo", "GameControl"]
}
